# Server
PORT=8090
APP_URL=http://localhost:5173
SECURE_COOKIE=false

# gRPC service addresses
KONFIG_API_ADDR=localhost:8081
KONFIG_DIST_ADDR=localhost:8082
KONFIG_VAL_ADDR=localhost:8083

# Database (shared with Konfig C++ services)
DATABASE_URL=postgres://configuser:configpass@localhost:5432/configservice?sslmode=disable

# JWT — change this to a long random string in production
JWT_SECRET=change-me-in-production

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Super admin seeded on first startup
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@konfig.local
SUPER_ADMIN_PASSWORD=changeme123
